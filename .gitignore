# compiled server binaries
bin/

# Wails desktop build output
build/

# frontend build output (regenerated by `npm run build` or `wails build`)
frontend/dist/

# npm dependencies
frontend/node_modules/

# Wails generates this to track whether npm install needs to re-run
frontend/package.json.md5

# Wails auto-generates JS bindings here during `wails dev` / `wails generate`
# Regenerate with: wails generate bindings
frontend/wailsjs/

# SQLite databases — local message store and mailbox
*.db

# server logs
*.log
logs/

# macOS
.DS_Store

# SSH control socket left by deploy.sh
.ssh/chatiss-deploy-ctl

# private keys
*.key
